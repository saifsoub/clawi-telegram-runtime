# @clawi_bot — VPS production (.env on server)
# cp deploy/.env.vps.example .env

TELEGRAM_BOT_TOKEN=
GROQ_API_KEY=

OWNER_NAME=Seif Alsoub
PRIVATE_MODE=true
AUTO_PAIR_FIRST_USER=false
OWNER_TELEGRAM_USER_ID=
SEIF_CHAT_ID=

BOT_MODE=polling
PORT=8080
STORAGE_DIR=./data
GROQ_MODEL=llama-3.3-70b-versatile
STREAMING=true

GROUP_ACTIVATION_WORDS=clawi
GROUP_REQUIRE_MENTION=true

INTERNAL_API_SECRET=change_me_long_random
N8N_SECRET=change_me_long_random

# AgentOS queue — n8n cloud or self-hosted
# Example: https://doneai.app.n8n.cloud/webhook/s-agentos-telegram-queue
N8N_WEBHOOK_URL=
N8N_MIRROR_WEBHOOK_URL=

ENABLE_MARKET_CRON=false
