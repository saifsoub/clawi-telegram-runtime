# Required
TELEGRAM_BOT_TOKEN=put_botfather_token_here
GROQ_API_KEY=put_groq_key_here

# Owner / private mode
OWNER_NAME=Seif Alsoub
PRIVATE_MODE=true
AUTO_PAIR_FIRST_USER=true
# After first /start, you can set this permanently from /whoami:
OWNER_TELEGRAM_USER_ID=
SEIF_CHAT_ID=
ALLOWED_TELEGRAM_USER_IDS=

# Groups
ALLOWED_GROUP_IDS=
GROUP_ALLOWED_USER_IDS=
GROUP_REQUIRE_MENTION=true
GROUP_ACTIVATION_WORDS=apex,sally,clawi

# Runtime
PORT=8080
BOT_MODE=polling
PUBLIC_BASE_URL=
WEBHOOK_SECRET=change_me_if_webhook
INTERNAL_API_SECRET=change_me_for_n8n
GROQ_MODEL=llama-3.3-70b-versatile
STREAMING=true
STORAGE_DIR=./data

# n8n bridge
N8N_WEBHOOK_URL=
N8N_MIRROR_WEBHOOK_URL=
N8N_SECRET=change_me_for_n8n

# Market cron
ENABLE_MARKET_CRON=false
MARKET_CRON=0 8,18 * * *

# Wallet safe mode — no private keys here
TON_WALLET_ADDRESS=
TON_WALLET_WEBHOOK_URL=
